{
  "name": "figseed",
  "version": "1.0.0",
  "private": true,
  "description": "Generate a shadcn/ui design system as Figma variables from a preset code.",
  "license": "MIT",
  "author": "Praveen Juge",
  "homepage": "https://github.com/praveenjuge/figseed#readme",
  "bugs": {
    "url": "https://github.com/praveenjuge/figseed/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/figseed.git"
  },
  "keywords": [
    "figma",
    "figma-plugin",
    "shadcn",
    "shadcn-ui",
    "design-system",
    "design-tokens",
    "tailwindcss",
    "variables"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.108.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.24.0",
    "quickjs-emscripten": "^0.32.0",
    "sharp": "^0.34.5",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
